#!/usr/bin/env bash
. "$scripts/installer.sh"
. "$scripts/logger.sh"

cacheFlag="/var/latestNodeIsInstalled"
versionCache="/var/latestNodeVersion"

installNode() {
    sudo apt-get update -y
    sudo apt-get install -y curl ca-certificates gnupg jq
    curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash -
    sudo apt-get install -y nodejs

    echo 'export NODE_OPTIONS="--trace-deprecation"' >> ~/.bashrc
    export NODE_OPTIONS="--trace-deprecation"
}

installedVersion=$(node --version 2>/dev/null || true)

if [[ -f "$cacheFlag" && -n "$installedVersion" ]]; then
    success "Node.js already up-to-date (cached) $checkMark"
    exit 0
fi

latestLts=""

if [[ -f "$versionCache" ]]; then
    latestLts=$(cat "$versionCache")
else
    latestLts=$(curl -s https://nodejs.org/dist/index.json | jq -r '[.[] | select(.lts != false)][0].version')
    echo "$latestLts" | sudo tee "$versionCache" >/dev/null
fi

if [[ -z "$latestLts" ]]; then
    errorAndExit "Change your internet or DNS"
fi

if [[ "$installedVersion" == "$latestLts" ]]; then
    success "Node.js is up to date $checkMark"
    sudo touch "$cacheFlag"
else
    sudo rm -f "$cacheFlag"
    install node installNode
fi
