#!/usr/bin/env bash

. "$scripts/installer.sh"

installRemoteContainers() {
    local ext="ms-vscode-remote.remote-containers"
    local installed
    local latest

    installed=$(code --list-extensions --show-versions 2>/dev/null \
        | grep "$ext" \
        | awk -F'[@]' '{print $2}')

    # latest=$(curl -s -X POST \
    #     -H "Content-Type: application/json" \
    #     -H "Accept: application/json; api-version=7.1-preview.1" \
    #     --data '{
    #         "filters":[
    #             {
    #                 "criteria":[{"filterType":7,"value":"ms-vscode-remote.remote-containers"}]
    #             }
    #         ],
    #         "flags":914
    #     }' \
    #     "https://marketplace.visualstudio.com/_apis/public/gallery/extensionquery?api-version=7.1-preview.1" \
    #     | grep -oP '"version":"\K[^"]+' \
    #     | head -n 1)
    latest=0.431.1

    if [ -n "$installed" ] && [ "$installed" = "$latest" ]; then
        return
    fi

    code --uninstall-extension "$ext" >/dev/null 2>&1 || true
    timeout 50s code --install-extension "$ext" --force
}

install vscode-remote-containers installRemoteContainers
