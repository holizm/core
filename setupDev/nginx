#!/usr/bin/env node

import os from 'os'
import {
    getContent,
    writeFile,
} from "../scripts/os.js"
import {
    info,
    warning,
} from "../scripts/logger.js"
import { runOnTerminal } from "../scripts/terminal.js"

const homeDir = process.env.homeDir
const nginxConf = '/etc/nginx/nginx.conf'
const includeLine = `\tinclude ${homeDir}/webServer/conf.d/*.conf;`

let content = getContent(nginxConf)

if (!content.includes(includeLine.trim())) {
    const marker = 'include /etc/nginx/sites-enabled/*;'
    const idx = content.indexOf(marker)

    if (idx !== -1) {
        const insertPos = idx + marker.length
        content = content.slice(0, insertPos) + os.EOL + includeLine + content.slice(insertPos)
        writeFile(nginxConf, content)
        info('Include line added')
    } else {
        warning('Marker line not found. Include not added.')
    }
} else {
    info('Include line already present')
}

runOnTerminal(`chmod o+rx ${homeDir}`)
runOnTerminal(`chmod o+rx ${homeDir}/core`)
runOnTerminal(`chmod o+rx ${homeDir}/core/webServer`)
