
            - name: Copy holism modules
              run: |
                    rm -rf /tmp/build/holismModulesInNodeModules
                    mkdir -p /tmp/build/holismModulesInNodeModules

                    if [ -d "/tmp/build/$repo/$process/node_modules" ]; then
                        cd "/tmp/build/$repo/$process/node_modules"

                        find -type f -name part -not -path '*/*-*/*' | sort | while read file; do
                            parent=$(dirname "$file")
                            name=$(basename "$parent")

                            cp -R "$parent" "/tmp/build/holismModulesInNodeModules/$name"
                        done
                    fi
