name: ${process}

on:
    workflow_dispatch:

env:
    GH_TOKEN: ${{ secrets.PAT }}

jobs:
    buildAndPush:
        permissions: write-all
        runs-on: ubuntu-latest
        steps:

            - name: Initialize
              if: startsWith(runner.name, 'GitHub')
              run: |
                    echo "~/core/commands" >> $GITHUB_PATH
                    mkdir ~/secrets
                    mkdir -p ~/.ssh
                    echo "${{ secrets.SSH }}" > ~/.ssh/id_ed25519
                    chmod --preserve-root 400 ~/.ssh/id_ed25519
                    cd ~
                    git clone git@github.com:holizm/core
            
            - name: Extract org and repo
              run: |
                    echo "gitHubOrganization=${{ github.repository_owner }}" >> $GITHUB_ENV
                    echo "gitHubRepository=${{ github.event.repository.name }}" >> $GITHUB_ENV

            - name: Clone holizm
              if: startsWith(runner.name, 'GitHub')
              run: |
                    clone holizm
