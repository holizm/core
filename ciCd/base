name: ${process}

on:
  workflow_dispatch:

jobs:
  buildAndPush:
    permissions: write-all
    runs-on: ubuntu-latest
    steps:

      - name: Initialize
        run: |
          echo "~/core/commands" >> $GITHUB_PATH
          mkdir ~/secrets
          mkdir -p ~/.ssh
          echo "${{ secrets.SSH }}" > ~/.ssh/id_ed25519
          chmod --preserve-root 400 ~/.ssh/id_ed25519
          echo "${{ secrets.PAT }}" > ~/secrets/gitHubAccessToken
          cd ~
          git clone git@github.com:holizm/core
          IFS="/" read -r -a repo_array <<< "${GITHUB_REPOSITORY}"
          echo "gitHubOrganization=${repo_array[0]}" >> $GITHUB_ENV
          echo "gitHubRepository=${repo_array[1]}" >> $GITHUB_ENV

      - name: Clone gesht
        run: |
          clone gesht
