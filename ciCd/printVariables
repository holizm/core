
            - name: Print variables
              run: |

                    runnerUser=$(whoami)
                    runnerHome="/home/$runnerUser"
                    
                    echo "HOME inside the runner (hosted or self-hosted) = $HOME"
                    echo "Users list:"
                    ls -lah /home
                    echo "HOME dir list:"
                    ls -lah $HOME
                    echo "Process path (inside runnable):"
                    echo "$HOME/$repo/$process"

                    # cat /tmp/$gitHubRepository/$process/compose.yaml

                    echo "Inside container: ls -lah /home"
                    docker exec "$container" bash -c "ls -lah /home"

                    echo "Inside container, runner home: ls -lah $runnerHome"
                    docker exec "$container" bash -c "ls -lah $runnerHome"

                    echo "Inside container, home: ls -lah $HOME"
                    docker exec "$container" bash -c "ls -lah $HOME"

                    echo "Copied items => ls -lah /tmp/build"
                    ls -lah /tmp/build
