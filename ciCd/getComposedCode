
            - name: Get the composed code
              run: |
                    rm -rf /tmp/build
                    mkdir -p /tmp/build

                    docker exec "$container" bash -c "
                        for dir in $containerHome/*; do
                            if [ -d \"\$dir\" ]; then
                                echo \$dir
                            fi
                        done
                    " | while read repo; do
                        name=$(basename "$repo")
                        docker cp "$container":"$repo" "/tmp/build/$name"
                    done

                    docker cp "$container":"$containerHome/spl" /tmp/build/spl || true

                    ls -lah /tmp/build
