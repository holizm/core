
            - name: Get the composed code
              run: |
                    mkdir -p /tmp/build

                    cat /tmp/$gitHubRepository/$process/compose.yaml

                    docker exec "$container" bash -c 'ls -lah /home'

                    docker exec "$container" bash -c 'echo $HOME'

                    docker exec "$container" bash -c 'echo "Inside container, HOME=$HOME"'
                    
                    docker exec "$container" bash -c "
                        for dir in \$HOME/*; do
                            if [ -d \"\$dir/.git\" ]; then
                                echo \$dir
                            fi
                        done
                    " | while read repo; do
                        name=$(basename "$repo")
                        docker cp "$container":"$repo" "/tmp/build/$name"
                    done

                    docker cp "$container":"$HOME/spl" /tmp/build/spl || true

                    ls -lah /tmp/build
