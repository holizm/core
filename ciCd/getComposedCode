
            - name: Get the composed code
              run: |
                    mkdir -p /tmp/build

                    runnerUser=$(whoami)
                    runnerHome="/home/$runnerUser"

                    # cat /tmp/$gitHubRepository/$process/compose.yaml

                    echo "Inside container: ls -lah /home"
                    docker exec "$container" bash -c "ls -lah /home"

                    echo "Inside container, runner home: ls -lah /home/$runnerHome"
                    docker exec "$container" bash -c "ls -lah /home/$runnerHome"

                    echo "Inside container, home: ls -lah /home/$HOME"
                    docker exec "$container" bash -c "ls -lah /home/$HOME"

                    docker exec "$container" bash -c "
                        for dir in $runnerHome/*; do
                            if [ -d \"\$dir/.git\" ]; then
                                echo \$dir
                            fi
                        done
                    " | while read repo; do
                        name=$(basename "$repo")
                        docker cp "$container":"$repo" "/tmp/build/$name"
                    done

                    docker cp "$container":"$runnerHome/spl" /tmp/build/spl || true

                    ls -lah /tmp/build
