
            - name: Get the composed code
              run: |
                    mkdir -p /tmp/build

                    runnerUser=$(whoami)
                    runnerHome="/home/$runnerUser"

                    docker exec "$container" bash -c "
                        for dir in $runnerHome/*; do
                            if [ -d \"\$dir\" ]; then
                                if [ -d \"\$dir/.git\" ]; then
                                    echo \"[GIT FOUND] \$dir/.git exists\"
                                else
                                    echo \"[NO GIT] \$dir/.git missing\"
                                fi
                            fi
                        done
                    "

                    docker exec "$container" bash -c "
                        for dir in $runnerHome/*; do
                            if [ -d \"\$dir\" ]; then
                                echo \$dir
                            fi
                        done
                    " | while read repo; do
                        name=$(basename "$repo")
                        docker cp "$container":"$repo" "/tmp/build/$name"
                    done

                    docker cp "$container":"$runnerHome/spl" /tmp/build/spl || true
