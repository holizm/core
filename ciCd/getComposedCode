
            - name: Get the composed code
              run: |
                    docker ps
                    container=$(docker ps -q | head -n 1)

                    docker exec -it "$container" ls -la /home/runner
                    docker exec -it "$container" ls -la /home/dev

                    mkdir -p /tmp/dev

                    docker exec "$container" bash -c '
                        for dir in /home/runner/*; do
                            if [ -d "$dir/.git" ]; then
                                echo "$dir"
                            fi
                        done
                    ' | while read repo; do
                        name=$(basename "$repo")
                        docker cp "$container":"$repo" "/tmp/dev/$name"
                    done

                    docker cp "$container":/home/runner/spl /tmp/dev/spl
