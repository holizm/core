{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "runtimeExecutable": "nodemon",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "/${home}/${repo}/${process}/process.js",
            "runtimeArgs": [
                "--preserve-symlinks",
                "--watch",
                "/core",
                "--watch",
                "/$repo"
            ],
            "restart": true,
            "console": "integratedTerminal"
        }
    ]
}
