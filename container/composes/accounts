services:
    accounts:
        image: nefcanto/accounts
        container_name: ${containerName}
        hostname: accounts
        ports:
            - "${randomPort}:8080"
        working_dir: /opt/keycloak
        environment:
            - KEYCLOAK_IMPORT=/opt/keycloak/data/import/dev.json
            - KC_PROXY_HEADERS=xforwarded
            - KC_BOOTSTRAP_ADMIN_USERNAME=PZx91EOd84ydum8Z3E6z
            - KC_BOOTSTRAP_ADMIN_PASSWORD=JNC1gcUVL9O6ZMxr7vKm
            - KC_DB=postgres
            - KC_DB_URL_HOST=database
            - KC_DB_URL_DATABASE=accounts
            - KC_DB_USERNAME=FaMHJGecNag5DKryCH9d
            - KC_DB_PASSWORD=IC1joYMLZTT0fQMJ5qcz
            - KC_HTTP_ENABLED=true
            - KC_HOSTNAME_STRICT=false
            - KC_DIR=/opt/keycloak/data/import
        restart: always
        entrypoint:
            [
                "/bin/bash",
                "-c",
                "/opt/keycloak/bin/kc.sh start-dev --log-level=ROOT:ERROR --log-level=phone_code:DEBUG --spi-theme-template-cache-enabled=false --spi-theme-resource-cache-enabled=false --import-realm"
            ]
        depends_on:
            database:
                condition: service_healthy
        volumes:
            - ${home}/accounts/dev.json:/opt/keycloak/data/import/dev.json
            - ${home}/accounts/themes:/opt/keycloak/themes

    database:
        image: postgres:latest
        container_name: ${repo}AccountsDatabase
        ports:
            - ${accountsDatabaseRandomPort}:5432
        environment:
            - POSTGRES_DB=accounts
            - POSTGRES_USER=FaMHJGecNag5DKryCH9d
            - POSTGRES_PASSWORD=IC1joYMLZTT0fQMJ5qcz
        volumes:
            - ${home}/${repo}/accounts/databases:/var/lib/postgresql
        restart: always
        healthcheck:
            test: ["CMD-SHELL", "pg_isready -U ${accountsDatabaseUser}"]
            interval: 5s
            timeout: 5s
            retries: 10
