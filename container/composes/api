services:
    api:
        image: nefcanto/api:latest
        ${userLine}
        container_name: ${repo}${pascalizedProcess}
        hostname: api
        ports:
            - "${randomPort}:5000"
        working_dir: ${containerHome}/${repo}/${process}
        environment:
            - home=${containerHome}
            - containerHome=${containerHome}
            - org=${org}
            - repo=${repo}
            - process=${process}
            - processPath=${containerHome}/${repo}/${process}
            - apiOrg=${org}
            - apiRepo=${repo}
            - apiProcess=${process}
            - apiProcessPath=${containerHome}/${repo}/${process}
            - environment=development
            - host=${host}
            - migrationPath=/tmp/${repo}/migration
            - isCiCd=${isCiCd}

            ${environmentVariablesPlaceholder}
        volumes:
            - ${home}/packages/api:${containerHome}/.npm
            - /tmp/${repo}/migration:/tmp/${repo}/migration
            - /tmp/${repo}/storage:/tmp/${repo}storage

            - /etc/localtime:/etc/localtime:ro
            - /etc/timezone:/etc/timezone:ro

            - ${home}/core:${containerHome}/core
            - ${home}/core:${containerHome}/spl/core
            - ${home}/fonts:${containerHome}/fonts
            - ${home}/cloud:${containerHome}/cloud
            - ${home}/etl:${containerHome}/etl
            - ${home}/panel/localization:${containerHome}/panel/localization
            - ${home}/site/localization:${containerHome}/site/localization

            - ${home}/generation/common:${containerHome}/generation/common
            - ${home}/generation/database:${containerHome}/generation/database
            - ${home}/generation/order:${containerHome}/generation/order
            - ${home}/generation/process.js:${containerHome}/generation/process.js

            - ${home}/migration/adHoc:${containerHome}/migration/adHoc
            - ${home}/migration/environment.js:${containerHome}/migration/environment.js
            - ${home}/migration/process.js:${containerHome}/migration/process.js
            - ${home}/migration/migrators:${containerHome}/migration/migrators

            - ${home}/toMongo/importers:${containerHome}/toMongo/importers
            - ${home}/etl:${containerHome}/toMongo/etl
            - ${home}/toMongo/process.js:${containerHome}/toMongo/process.js

            - ${home}/query/partDropper.js:${containerHome}/query/partDropper.js
            - ${home}/query/process.js:${containerHome}/query/process.js

            - ${home}/${repo}/common/tenants:${containerHome}/${repo}/common/tenants
            - ${home}/${repo}/common/initial.js:${containerHome}/${repo}/common/initial.js
            - ${home}/${repo}/common/dependencies:${containerHome}/${repo}/common/dependencies

            - ${home}/secrets/common.json:${containerHome}/${repo}/${process}/common.json
            - ${home}/secrets/${repo}.json:${containerHome}/${repo}/${process}/secrets.json
            ${volumes}
            - /tmp/${repo}/${process}/.vscode:${containerHome}/${repo}/${process}/.vscode
        command: |
            bash -lc '
            export PATH=${containerHome}/core/commands/api:${containerHome}/core/commands:$PATH
            echo -e "\033[0;31mhttps://localhost:${randomPort}"
            merge api
            initialize
            if [ "${isCiCd}" != "true" ]; then
                prepare generation
                prepare migration
                prepare query
                prepare toMongo
                install
                if [ "${isEtl}" == "true" ]; then
                    echo "ETL"
                else
                    monitor &
                    cd ${containerHome}/${repo}/${process}
                    nodemon --watch /${repo} process.js &
                fi
            fi
            tail -f /dev/null
            '
        stdin_open: true
        tty: true
        networks:
            - ${repo}Network

networks:
    ${repo}Network:
        external: true
