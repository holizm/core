services:
    api:
        image: geshtio/api:latest
        container_name: ${repo}${pascalizedProcess}
        hostname: api
        working_dir: /${repo}/${process}
        environment:
            - org=${org}
            - repo=${repo}
            - process=${process}
            - processPath=/${repo}/${process}
            - apiOrg=${org}
            - apiRepo=${repo}
            - apiProcess=${process}
            - apiProcessPath=/${repo}/${process}
            - environment=development
            - host=${host}
            - migrationPath=/tmp/${repo}/migration

            ${environmentVariablesPlaceholder}
        volumes:
            - ${home}/.npm:/root/.npm
            - /tmp/${repo}/migration:/tmp/${repo}/migration
            - /tmp/${repo}/storage:/storage

            - /etc/localtime:/etc/localtime:ro
            - /etc/timezone:/etc/timezone:ro

            - ${home}/core:/core
            - ${home}/core:/spl/core
            - ${home}/fonts:/fonts
            - ${home}/cloud:/cloud
            - ${home}/etl:/etl
            - ${home}/panel/localization:/panel/localization
            - ${home}/site/localization:/site/localization

            - ${home}/generation/common:/generation/common
            - ${home}/generation/database:/generation/database
            - ${home}/generation/order:/generation/order
            - ${home}/generation/process.js:/generation/process.js

            - ${home}/migration/adHoc:/migration/adHoc
            - ${home}/migration/environment.js:/migration/environment.js
            - ${home}/migration/process.js:/migration/process.js
            - ${home}/migration/migrators:/migration/migrators

            - ${home}/toMongo/importers:/toMongo/importers
            - ${home}/toMongo/etl:/toMongo/etl
            - ${home}/toMongo/process.js:/toMongo/process.js

            - ${home}/query/partDropper.js:/query/partDropper.js
            - ${home}/query/process.js:/query/process.js

            - /${repo}/common:/${repo}/common

            - ${home}/secrets/common.json:/${repo}/${process}/common.json
            - ${home}/secrets/${repo}.json:/${repo}/${process}/secrets.json
            ${volumes}
            - /tmp/${repo}/${process}/.vscode:/${repo}/${process}/.vscode
        ports:
            - "${randomPort}:5000"
        command: |
            bash -lc '
            export PATH=/core/commands/api:/core/commands:$PATH
            echo -e "\033[0;31mhttps://localhost:${randomPort}"
            echo "Node"
            merge api
            echo "2"
            prepare generation
            echo "3"
            prepare migration
            echo "4"
            prepare query
            echo "5"
            prepare toMongo
            echo "6"
            symlinkCoreAndParts
            echo "7"
            monitor &
            echo "8"
            cd /${repo}/${process}
            echo "9"
            initialize
            echo "10"
            nodemon --watch /${repo} process.js &
            echo "11"
            tail -f /dev/null
            '
        stdin_open: true
        tty: true
        networks:
            - ${repo}Network

networks:
    ${repo}Network:
        external: true
