            - ${home}/core:${containerHome}/core
            - /var/tmp/${repo}/databases/data:/data/db
            - /var/tmp/${repo}/databases/replicaKey:/etc/mongo-keyfile
        environment:
            - MONGO_INITDB_ROOT_USERNAME=FaMHJGecNag5DKryCH9d
            - MONGO_INITDB_ROOT_PASSWORD=IC1joYMLZTT0fQMJ5qcz
        ports:
            - ${databaseEnginePort}:27017
        # logging:
        #     driver: none
        networks:
            - ${repo}Network
        # command: ["/bin/bash", "-c", "chown root:root /etc/mongo-keyfile && exec mongod --replSet rs0 --keyFile /etc/mongo-keyfile --bind_ip_all"]
