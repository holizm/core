services:
    site:
        image: geshtio/site
        container_name: ${repo}${process}
        hostname: site
        working_dir: ${processPath}
        environment:
            - NODE_TLS_REJECT_UNAUTHORIZED=0
            - org=${org}
            - repo=${repo}
            - process=${process}
            - processPath=${processPath}
            - randomPort=${randomPort}
            - AUTH_SECRET=t69bu9H55yXKQfUfx8fN
            - KEYCLOAK_CLIENT_SECRET=M8k36kf3wtF8JcO1F5vtiwHqI20dLmjU
            - KEYCLOAK_ISSUER=https://accounts.gesht.io/realms/development
            - PROTOCOL_HEADER=x-forwarded-proto
            - HOST_HEADER=x-forwarded-host
            # - NODE_ENV=production
        volumes:
            - /tmp/mre:/tmp/mre
            - /core:/core
            - /policies:/policies
            - /core/fonts:${processPath}/public/fonts
            - /site/:/site/
            - /site/core-package.json:/npm/core-package.json
            - /site/eslint.config.js:${processPath}/eslint.config.js
            - /site/.prettierignore:${processPath}/.prettierignore
            - /site/.prettierrc:${processPath}/.prettierrc
            - /site/adapters:${processPath}/adapters
            - /site/buildPolicies:${processPath}/buildPolicies
            - /site/base:${processPath}/src/base
            - /site/components:${processPath}/src/baseComponents
            - /site/getters:${processPath}/src/baseGetters
            - /site/functions:${processPath}/src/baseFunctions
            - /site/hooks:${processPath}/src/baseHooks
            - /site/contexts:${processPath}/src/baseContexts
            - /site/core-package.json:${processPath}/core-package.json
            - /site/postcss.config.js:${processPath}/postcss.config.js
            - /site/src/entry.dev.tsx:${processPath}/src/entry.dev.tsx
            - /site/src/entry.express.tsx:${processPath}/src/entry.express.tsx
            - /site/src/entry.preview.tsx:${processPath}/src/entry.preview.tsx
            - /site/src/entry.ssr.tsx:${processPath}/src/entry.ssr.tsx
            - /site/src/global.css:${processPath}/src/global.css
            - /site/src/plugin@_infra.ts:${processPath}/src/routes/plugin@_infra.ts
            - /site/src/root.jsx:${processPath}/src/root.tsx
            - /site/src/router-head.jsx:${processPath}/src/router-head.jsx
            - /site/src/routes/service-worker.ts:${processPath}/src/routes/service-worker.ts
            # - /site/src/routes/404.tsx:${processPath}/src/routes/404.tsx
            - /site/src/routes/error:${processPath}/src/routes/error
            - /site/src/routes/create-blobs:${processPath}/src/routes/create-blobs
            - /site/tsConfigBase.json:${processPath}/tsConfigBase.json
            - /site/tailwindBase.css:${processPath}/tailwindBase.css
            - /site/richTextRendererCollector.js:${processPath}/richTextRendererCollector.js
            - /site/entityRendererCollector.js:${processPath}/entityRendererCollector.js
            - /site/paginationBehaviorCollector.js:${processPath}/paginationBehaviorCollector.js
            - /site/settingsCreator.js:${processPath}/settingsCreator.js
            - /site/classPrefixer.js:${processPath}/classPrefixer.js
            - /site/nullLayoutProvider.js:${processPath}/nullLayoutProvider.js
            - /site/emptyDashboardProvider.js:${processPath}/emptyDashboardProvider.js
            - /site/loaderProvider.js:${processPath}/loaderProvider.js
            - /site/telemetry.js:${processPath}/telemetry.js
            - /site/vite.config.js:${processPath}/vite.config.js
            - /site/scripts/scroll.js:${processPath}/public/scripts/scroll.js
            - /site/icons/markerIcon.png:${processPath}/public/icons/marker-icon.png
            - /site/icons/markerIcon2x.png:${processPath}/public/icons/marker-icon-2x.png
            - /site/icons/markerShadow.png:${processPath}/public/icons/marker-shadow.png
            - ${home}/secrets/${repo}.json:${processPath}/public/secrets.json
            - /tmp/$repo/$process/ast:/tmp/$repo/$process/ast
            - /tmp/$repo/$process/analysis:/tmp/$repo/$process/analysis
            - /tmp/$repo/$process/nginxCache:/nginxCache
            - ${processPath}/tailwind.css:${processPath}/tailwind.css

            # - DependenciesPlaceholder

        command: >
            bash -c
            "
            cd ${processPath}
            && ln -s -f /npm/node_modules ${processPath}
            && echo -e '\033[0;31m'"http://localhost:$randomPort" "https://$host"
            && watchForDirectoryChanges &
            watchForAst &
            initialize &&
            start &
            tail -f /dev/null
            "
        network_mode: "host"
