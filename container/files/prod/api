FROM nefcanto/api AS builder

USER root
RUN chown -R dev:dev /home/dev

USER dev
COPY --chown=dev:dev . /home/dev

WORKDIR ${processPath}
RUN ls -ld /home/dev
RUN npm install --legacy-peer-deps

RUN ls -lah /home/dev
RUN ls -lah /home/dev/holismModulesInNodeModules

RUN if [ -d "/home/dev/holismModulesInNodeModules" ]; then \
  mkdir -p "/home/dev/$repo/$process/node_modules" && \
  find /home/dev/holismModulesInNodeModules -mindepth 1 -maxdepth 1 -type d -exec cp -r {} "/home/dev/$repo/$process/node_modules/" \; && \
  rm -rf "/home/dev/holismModulesInNodeModules"; \
fi

RUN mkdir -p /home/export && \
find /home/dev -mindepth 1 -maxdepth 1 -type d -exec cp -a {} /home/export/ \;

FROM nefcanto/api-prod-base:latest
COPY --from=builder /home/export/. /home/node/
RUN chown -R node:node /home/node
WORKDIR /home/node/${repo}/${process}
ENV PATH="${PATH}:/home/node/core/commands"
USER node
CMD ["node", "/home/node/${repo}/${process}/process.js"]
