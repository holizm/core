FROM nefcanto/api AS builder

USER root
RUN chown -R dev:dev /home/dev

USER dev
COPY --chown=dev:dev . /home/dev

WORKDIR /home/dev/${repo}/${process}
RUN ls -ld /home/dev
RUN ls -lah /home/dev
RUN ls -lah /home/dev/holismModulesInNodeModules

RUN npm install --legacy-peer-deps

RUN set -e && \
  if [ -d "/home/dev/holismModulesInNodeModules" ]; then \
    echo "Found holismModulesInNodeModules, starting copy..." && \
    mkdir -p "/home/dev/${repo}/${process}/node_modules" && \
    echo "Target node_modules created at /home/dev/${repo}/${process}/node_modules" && \
    cp -r /home/dev/holismModulesInNodeModules/* "/home/dev/${repo}/${process}/node_modules/" && \
    echo "Copy completed successfully" && \
    rm -rf /home/dev/holismModulesInNodeModules && \
    echo "Source directory removed"; \
  else \
    echo "holismModulesInNodeModules not found, skipping copy"; \
  fi

RUN mkdir -p /tmp/export && \
find /home/dev -mindepth 1 -maxdepth 1 -type d -exec cp -a {} /tmp/export/ \;

FROM nefcanto/api-prod-base:latest
COPY --from=builder /tmp/export/. /home/node/
RUN chown -R node:node /home/node
WORKDIR /home/node/${repo}/${process}
ENV PATH="${PATH}:/home/node/core/commands"
USER node
CMD [ "/bin/bash", "-c", "/home/node/${repo}/${process}/process.js & tail -f /dev/null" ]
# CMD ["node", "/home/node/${repo}/${process}/process.js"]
