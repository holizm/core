FROM node:lts-trixie-slim

RUN sed -i 's/^Components: main$/& contrib non-free-firmware/' /etc/apt/sources.list.d/debian.sources

RUN apt update -qq \
    && mkdir -p /tmp/imageResizingAndCompression \
    && mkdir -p /tmp/videoConversion \
    && apt install -qq -y apt-utils libgdiplus libc6-dev \
    && apt install -qq -y procps \
    && apt install -qq webp -y \
    && apt install -qq file -y \
    && apt install -qq imagemagick -y \
    && apt install -qq bsdmainutils -y \
    && apt install -qq translate-shell -y \
    && apt install -qq ffmpeg -y
