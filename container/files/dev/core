FROM node:lts-trixie-slim

RUN groupadd --gid 1000 dev \
    && useradd --uid 1000 --gid dev --shell /bin/bash --create-home dev \
    && mkdir -p /home/dev && chown -R dev:dev /home/dev

RUN sed -i 's/^Components: main$/& contrib non-free-firmware/' /etc/apt/sources.list.d/debian.sources \
    && apt-get update -qq -y \
    && apt-get upgrade -qq -y \
    && apt-get install -y --no-install-recommends \
        git procps curl inotify-tools jq python3 make g++ unzip bc jo \
    && npm install --location=global npm npm-check \
    && cd /usr/local/bin && curl -fsSL https://getmic.ro | bash \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

USER dev

WORKDIR /home/dev
