{
    "usage": [
        "Open the workspace directory, the directory that the command wants to be executed in.",
        "Copy/paste this file into .vscode/launch.json there.",
        "Fix the command's path in the `program` attribute",
        "Use the Run menu => Start debugging"
    ],
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Run",
            "program": "${workspaceFolder}/../server/commands/generate",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--inspect-brk"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}
