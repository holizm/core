{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Run",
            "program": "${workspaceFolder}/../server/commands/generate",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--inspect-brk"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}
