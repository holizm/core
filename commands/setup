#!/usr/bin/env bash
set -euo pipefail

# https://iran.chabokan.net/
# https://www.arvancloud.ir/fa/dev/linux-repository

homeDir=$(getent passwd "${SUDO_USER:-$USER}" | cut -d: -f6)
setupDev="$homeDir/core/setupDev"
scripts="$homeDir/core/scripts"

export homeDir
export setupDev
export scripts

. "$scripts/logger.sh"

clear
divide
info "running setup ..."
divide

$setupDev/setup

node "$homeDir/core/hooks/installHooks.js"
node "$homeDir/core/commands/installCommands.js"
node "$homeDir/core/scripts/setVcsIgnores.js"

. "$scripts/configureHosts.sh"

success "setup complete"
