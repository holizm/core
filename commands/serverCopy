#!/usr/bin/env bash

. $HOME/core/scripts/logger.sh

sourcePath=$1
destinationPath=$2

if [[ -z "$sourcePath" || -z "$destinationPath" ]]; then
    error "Usage: scp source destination"
    exit 1
fi

if [[ "$sourcePath" == *:* ]]; then
    remote="$sourcePath"
    localPath="$destinationPath"
elif [[ "$destinationPath" == *:* ]]; then
    remote="$destinationPath"
    localPath="$sourcePath"
else
    error "Either source or destination must be remote."
    exit 1
fi

domain="${remote%%:*}"
remotePath="${remote#*:}"

if [[ -z "$remotePath" || "$remotePath" == "$remote" ]]; then
    error "Invalid remote path. Use the format domain:/path/to/file"
    exit 1
fi

read -r sshPort sshUser sshIp < <(node ~/core/scripts/extractSshParameters.js "$domain")

if [[ -z "$sshPort" || -z "$sshUser" || -z "$sshIp" ]]; then
    error "Failed to extract SSH parameters for $domain"
    exit 1
fi

if ssh -p "$sshPort" "$sshUser@$sshIp" "test -d '$remotePath'" >/dev/null 2>&1; then
    scpFlags="-r"
else
    scpFlags=""
fi

if [[ "$sourcePath" == *:* ]]; then
    scp -P "$sshPort" $scpFlags "$sshUser@$sshIp:$remotePath" "$localPath"
else
    scp -P "$sshPort" $scpFlags "$localPath" "$sshUser@$sshIp:$remotePath"
fi
