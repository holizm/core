#!/usr/bin/env node

import fs from 'fs'

const hostsPath = '/etc/hosts'

const content = fs.readFileSync(hostsPath, 'utf8')

const lines = content
    .split('\n')
    .filter(line => {
        const trimmed = line.trim()

        if (!trimmed)
            return true

        if (trimmed.startsWith('#'))
            return true

        const parts = trimmed.split(/\s+/)

        if (parts[0] !== '127.0.0.1')
            return true

        const hosts = parts.slice(1)

        return hosts.includes('localhost') || hosts.includes('local')
    })

fs.writeFileSync(
    hostsPath,
    lines.join('\n')
)

console.log('DNS reset completed')
