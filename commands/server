#!/usr/bin/env bash

. $HOME/core/scripts/logger.sh

if [[ $PWD != "/" ]]; then
    error "Go to / first, then Ssh from there."
    exit 1
fi

domain=$1
shift

# 🔹 Call the Node helper to extract SSH parameters
read -r sshPort sshUser sshIp < <(node /path/to/extractSshParameters.js "$domain")

if [[ -z "$sshPort" || -z "$sshUser" || -z "$sshIp" ]]; then
    error "Failed to extract SSH parameters for $domain"
    exit 1
fi

if [[ $# -gt 0 ]]; then
    ssh -A -o ServerAliveInterval=15 -p "$sshPort" "$sshUser@$sshIp" "$@"
else
    ssh -A -t -o ServerAliveInterval=15 -p "$sshPort" "$sshUser@$sshIp" "sudo -i"
fi
