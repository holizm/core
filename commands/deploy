#!/usr/bin/env node

import {
    clear,
    runOnTerminal,
    runStreaming,
} from '../scripts/terminal.js'
import {
    divide,
    errorAndExit,
    info,
} from '../scripts/logger.js'
import build from '../scripts/build.js'
import runOnServer from '../scripts/runOnServer.js'

const domain = process.argv[2]
if (!domain) {
    errorAndExit('Domain is not provided')
}

clear()

divide()
info('holism deploy')
divide()

const params = await build({
    isCiCd: false,
    localBuild: true,
})

const {
    processBuildDir,
    repo,
} = params

await runOnServer(domain, `mkdir -p /tmp/${repo}`)

divide()
info('Copying to the server...')
divide()

await runStreaming(`serverCopy ${processBuildDir}/${params.process}.zip ${domain}:/tmp/${repo}`)

divide()

await runOnServer(domain, `mv /tmp/${repo}/${params.process}.zip $HOME/${repo}/${params.process}`)
await runOnServer(domain, `cd $HOME/${repo}/${params.process} && unzip -o ${params.process}.zip`)
await runOnServer(domain, `cd $HOME/${repo}/${params.process} && npm install --registry="https://mirror-npm.runflare.com" --legacy-peer-deps`)

info('Done')
