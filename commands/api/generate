#!/usr/bin/env node

import path from 'path'
import {
    startTimer,
    stopTimer
} from '../../scripts/timer.js'
import {
    divide,
    error,
    errorAndExit,
    info,
    warning,
} from '../../scripts/logger.js'
import {
    clear,
    runOnTerminal,
} from '../../scripts/terminal.js'
import {
    getLines,
    isDir,
    isFile,
} from '../../scripts/os.js'
import extract from '../../scripts/extract.js'
import run from './run'

const isDirectExecution =
    process.argv[1] &&
    path.resolve(process.argv[1]) === path.resolve(import.meta.filename)

if (isDirectExecution) {
    clear()
}

const args = process.argv.slice(2)
let search = args[0] || ''
const { home } = process.env

startTimer()

if (!search) {
    runOnTerminal('dropAll', { show: true })

    const {
        process: proc,
        repo,
        apiRepository,
    } = process.env

    const essentialPartsPath = `${home}/core/essentialParts`
    const partsPath = `${home}/${repo}/common/dependencies`
    const orderFile = `${home}/generation/order`
    const orderList = getLines(orderFile)
    const essentialParts = getLines(essentialPartsPath)
    const parts = getLines(partsPath)

    const set = Array.from(new Set([...essentialParts, ...parts]))

    const first = orderList.filter(x => set.includes(x))
    const second = set.filter(x => !orderList.includes(x))
    const finalList = [...first, ...second]

    for (const part of finalList) {
        let orgOrRepo
        if (isDir(`${home}/${apiRepository}/${part}`)) {
            orgOrRepo = apiRepository
        } else {
            orgOrRepo = 'holizm'
        }

        const base = `${home}/${part}`
        const partFile = `${base}/part`

        if (!isFile(partFile)) {
            warning(`Did not find part file for ${partFile}`)
            continue
        }

        process.chdir(base)
        runOnTerminal(`generate ${part}`, { show: true })
    }

    // runOnTerminal('insertData', { show: true })
    stopTimer()
    process.exit(0)
}

search = search.replace('/', '')

const command = `
    find ${home} \
        -maxdepth 1 -mindepth 1 -type d \
        -name '*${search}*' \
        -exec test -f '{}/part' \\; \
        -print 2>/dev/null
`
const result = runOnTerminal(command)
const dirs = result.split('\n').filter(Boolean)
if (dirs.length > 1) {
    for (const dir of dirs) {
        const partFile = `${dir}/part`
        if (isFile(partFile)) {
            process.chdir(dir)
            runOnTerminal(`generate ${dir}`, { show: true })
        }
    }
    stopTimer()
    process.exit(0)
}

if (dirs.length === 0) {
    errorAndExit(`No part is found for search ${search}`)
}

process.chdir(dirs[0])
divide()
const params = extract({
    container: true,
})
divide()
const partFile = `${home}/${params.repo}/part`

if (!isFile(partFile)) {
    warning(`Did not find ${partFile}`)
    stopTimer()
    process.exit(0)
}

await run({
    app: 'generation',
    part: params.repo,
    partPath: `${home}/${params.repo}`,
    show: true,
})

stopTimer()
