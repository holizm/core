#!/usr/bin/env node

import path from 'path'
import {
    startTimer,
    stopTimer
} from '../../scripts/timer.js'
import {
    divide,
    info,
    warning,
} from '../../scripts/logger.js'
import { runOnTerminal } from '../../scripts/terminal.js'
import {
    getFileLines,
    isDir,
    isFile,
} from "../../scripts/os.js"
import extract from "../../scripts/extract.js"
import run from "./run"

const args = process.argv.slice(2)
let name = args[0] || ''
divide()
const params = extract({
    container: true,
})
divide()

startTimer()

if (!name) {
    runOnTerminal('dropAll', { show: true })

    const {
        process: proc,
        repo,
        apiRepository,
    } = process.env

    const essentialPartsPath = `/core/essentialParts`
    const partsPath = `/${repo}/common/dependencies`
    const orderFile = '/generation/order'
    const orderList = getFileLines(orderFile)
    const essentialParts = getFileLines(essentialPartsPath)
    const parts = getFileLines(partsPath)

    const set = new Set([...essentialParts, ...parts])

    const first = orderList.filter(x => set.has(x))
    const second = parts.filter(x => !orderList.includes(x))
    const finalList = [...first, ...second]

    for (const part of finalList) {
        let orgOrRepo
        if (isDir(`/${apiRepository}/${part}`)) {
            orgOrRepo = apiRepository
        } else {
            orgOrRepo = 'holizm'
        }

        const base = `/${part}`
        const partFile = `${base}/part`

        if (!isFile(partFile)) {
            warning(`Did not find part file for ${partFile}`)
            continue
        }

        process.chdir(base)
        runOnTerminal(`generate ${part}`, { show: true })
    }

    // runOnTerminal('insertData', { show: true })
    stopTimer()
    process.exit(0)
}

name = name.replace('/', '')

const command = `
        find /spl \
            -maxdepth 1 -mindepth 1 -type d \
            -not -name "core" \
            -name '*${name}*' 2>/dev/null
    `
const result = runOnTerminal(command)
const dirs = result.split('\n').filter(Boolean)
if (dirs.length > 1) {
    for (const dir of dirs) {
        const partFile = path.join(dir, 'part')
        if (isFile(partFile)) {
            process.chdir(dir)
            runOnTerminal(`generate ${dir}`, { show: true })
        }
    }
    stopTimer()
    process.exit(0)
}

const pwd = process.cwd()
const partFile = path.join(pwd, 'part')

if (!isFile(partFile)) {
    warning(`Did not find ${pwd}/part`)
    stopTimer()
    process.exit(0)
}

// run(params)
console.log("running run with", params)

stopTimer()
