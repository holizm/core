#!/usr/bin/env node

import { isFile } from "../../scripts/os.js"
import {
    clear,
    runOnTerminal,
} from '../../scripts/terminal.js'
import run from './run'

const {
    apiRepo,
    home,
} = process.env

clear()

const findCmd = `find / -type f -path "*/api/data/*" -not -path '*/node_modules/*' -name "*.json" -printf "%p\n" 2>/dev/null`
let files = runOnTerminal(findCmd).split('\n')

let initialFile = `${home}/${apiRepo}/common/initial.js`
if (isFile(initialFile)) files.push(initialFile)
await run({
    app: 'query',
    command: 'insertData',
    files,
    show: true,
})
