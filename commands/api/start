#!/usr/bin/env node

import {
    divide,
    info,
} from '../../scripts/logger.js'
import { isFile } from '../../scripts/os.js'
import {
    clear,
    runOnTerminal,
    runStreaming,
} from '../../scripts/terminal.js'

const {
    process: proc,
    repo,
} = process.env

const main = async () => {
    clear()
    runOnTerminal('stop')

    divide()
    if (isFile('package.json')) {
        info('Starting...')
    } else {
        info(`Starting /${repo}/${proc} ...`)
    }
    divide()
    const command = `nodemon --watch /${repo} --ignore "**/*.json" process.js`
    console.log(command)
    await runStreaming(command)
}

main().catch(e => {
    info(String(e))
})
