#!/usr/bin/env node

import {
    error,
    info,
} from '../../scripts/logger.js'
import {
    createDirIfNotExists,
    getDirsAndFiles,
    isDir,
    removeAndRecreateDir,
} from '../../scripts/os.js'
import run from './run'

const {
    apiRepo,
    home,
} = process.env

const parts = process.argv[2] || ''
const type = process.argv[3] || ''

const migrationBaseDir = '/tmp'
const developmentPath = `${migrationBaseDir}/${apiRepo}/migration/development`
const productionPath = `${migrationBaseDir}/${apiRepo}/migration/production`

function makeDirectories() {
    if (!isDir(developmentPath)) {
        createDirIfNotExists(developmentPath)
        info(`Created directory: ${developmentPath}`)
    }
    if (!isDir(productionPath)) {
        createDirIfNotExists(productionPath)
        info(`Created directory: ${productionPath}`)
    }
}

function deleteMatching(basePath, part, typeFilter = '') {
    if (!isDir(basePath)) return

    const files = getDirsAndFiles(basePath)
    for (const file of files) {
        const filePath = `${basePath}/${file}`
        const shouldDelete = file.includes(part) && (!typeFilter || file.includes(typeFilter))
        if (shouldDelete) {
            try {
                if (isDir(filePath)) {
                    removeAndRecreateDir(filePath)
                    info(`Removed directory: ${filePath}`)
                } else {
                    deleteFile(filePath)
                    info(`Removed file: ${filePath}`)
                }
            } catch (e) {
                error(`❌ Error removing ${filePath}:`, e.message)
            }
        }
    }
}

function createScripts(part = '') {

    const params = {
        app: 'migration',
        show: true,
        command: 'generateScripts',
        storagePath: `${migrationBaseDir}/${apiRepo}/migration`,
        repo: apiRepo,
        part,
        type,
    }

    run({
        environment: 'development',
        ...params,
    })

    run({
        environment: 'production',
        ...params,
    })
}

function createScriptForPart(part) {
    if (!type) {
        deleteMatching(developmentPath, part)
        deleteMatching(productionPath, part)
        createScripts(part)
    } else {
        deleteMatching(developmentPath, part, type)
        deleteMatching(productionPath, part, type)
        createScripts(part)
    }
}

if (!parts) {
    removeAndRecreateDir(developmentPath)
    removeAndRecreateDir(productionPath)
    makeDirectories()
    createScripts()
} else {
    if (parts.includes(',')) {
        const parts = parts
            .split(',')
            .map(p => p.trim().replace(/\//g, ''))
        for (const item of parts) {
            createScriptForPart(item)
        }
    } else {
        const part = parts.replace(/\//g, '')
        createScriptForPart(part)
    }
}
