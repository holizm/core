#!/usr/bin/env node

import {
    runStreaming,
} from '../../scripts/terminal.js'

export default async params => {
    const home = process.env.home
    const {
        app,
        ...rest
    } = params
    const args = Object.entries(rest)
        .map(([k, v]) => `${k}=${v}`)
        .join(' ')
    const cmd = `node --preserve-symlinks ${home}/${app}/process.js ${args}`
    await runStreaming(cmd, params)
}
