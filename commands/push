#!/usr/bin/env node

import readline from 'readline'
import {
    runOnTerminal,
    runStreaming
} from '../scripts/terminal.js'
import {
    divide,
    errorAndExit,
    info,
    success,
    warning,
} from "../scripts/logger.js"
import findRepos from "../scripts/findRepos.js"
import status from "../scripts/status.js"

const gitGet = key =>
    runOnTerminal(`git config --global ${key}`, { show: false })

const ensureGitConfig = () => {
    const gitName = gitGet('user.name')
    const gitEmail = gitGet('user.email')
    const gpgFormat = gitGet('gpg.format')
    const signingKey = gitGet('user.signingkey')
    const commitSign = gitGet('commit.gpgsign')

    if (!gitName) errorAndExit('Git user.name is not set')
    if (!gitEmail) errorAndExit('Git user.email is not set')
    if (gpgFormat !== 'ssh') errorAndExit("Git gpg.format is not 'ssh'")
    if (!signingKey) errorAndExit('Git user.signingkey is not set')
    if (commitSign !== 'true') errorAndExit('Git commit.gpgsign is not enabled')

    info()
    info(`Git configuration OK: ${gitName} <${gitEmail}>, signing enabled with ${signingKey}`)
}

const promptYesNo = async question => {
    const rl = readline.createInterface({
        input: process.stdin,
        output: process.stdout,
    })
    const answer = await new Promise(resolve =>
        rl.question(question, a => resolve(a.trim()))
    )
    rl.close()
    return answer.toLowerCase() === 'y'
}

const commitRepo = dir => {
    const porcelain = runOnTerminal(`git -C ${dir} status --porcelain`)
    if (!porcelain) return false

    info(`Committing ${dir}`)
    runOnTerminal(`git -C ${dir} add .`)
    runOnTerminal(`git -C ${dir} commit -S -m "committed by script"`)

    return true
}

const pushRepoStreaming = async dir => {
    info(`→ pushing ${dir}`)

    try {
        await runStreaming(`git -C ${dir} push`)
        success(`✓ pushed ${dir}`)
    } catch (e) {
        warning(`Push failed for ${dir}, pulling and retrying...`)

        try {
            await runStreaming(`git -C ${dir} pull`)
            await runStreaming(`git -C ${dir} push`)
            success(`✓ pushed ${dir} after retry`)
        } catch (retryError) {
            warning(`✗ failed ${dir}: ${retryError.message}`)
        }
    }
}

const search = process.argv[2]

ensureGitConfig()
divide()
info('Getting the current status ...')
divide()

const results = status(search)

divide()
warning('Still pushing? (y,n)')
const ok = await promptYesNo('')
if (!ok) process.exit(0)

const repos = findRepos(search)

const toPush = []

for (const dir of repos) {
    if (commitRepo(dir)) toPush.push(dir)
}

const ahead = results
    .filter(r => r.type === 'ahead')
    .map(r => r.repo)

const unique = [...new Set([...toPush, ...ahead])]

divide()
info(`Pushing ${unique.length} repos in parallel`)
divide()

await Promise.all(unique.map(pushRepoStreaming))

divide()
success('Pushed all')
divide()
