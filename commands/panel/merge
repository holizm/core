#!/usr/bin/env node

import {
    getFileContent,
    isFile,
    writeFile,
} from '../../scripts/os.js'

const {
    process: proc,
    repo,
} = process.env
const base = `/${repo}/${proc}`
const corePath = `${base}/corePackage.json`
const panelPath = `${base}/panel.json`
const outPath = `${base}/package.json`

const deepMerge = (a, b) => {
    if (Array.isArray(a) || Array.isArray(b) || typeof a !== 'object' || typeof b !== 'object' || a === null || b === null) return b
    const r = { ...a }
    for (const k of Object.keys(b)) r[k] = k in a ? deepMerge(a[k], b[k]) : b[k]
    return r
}

const sortKeysDeep = (x) => {
    if (Array.isArray(x)) return x.map(sortKeysDeep)
    if (x && typeof x === 'object') {
        return Object.keys(x)
            .sort((a, b) => a.localeCompare(b))
            .reduce((acc, k) => {
                acc[k] = sortKeysDeep(x[k])
                return acc
            }, {})
    }
    return x
}

const core = JSON.parse(getFileContent(corePath))
const panel = isFile(panelPath)
    ?
    JSON.parse(getFileContent(panelPath))
    :
    {}
const merged = deepMerge(panel, core)
const sorted = sortKeysDeep(merged)

writeFile(outPath, JSON.stringify(sorted, null, 4) + '\n')
