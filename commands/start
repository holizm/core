#!/usr/bin/env node

import fs from "fs"
import path from "path"
import process from "process"
import { execSync } from "child_process"
import {
    errorAndExit,
    divide,
    info,
    success,
} from "../logger.js"
import {
    getDepth,
    getFileLines,
    getOrgRepoFromGit,
    isFile,
} from "../scripts/os"
import { clear } from "../scripts/terminal"
import getPaths from "../scripts/getPaths.js"

clear()

const cwd = process.cwd()
if (cwd === "/") {
    errorAndExit("Can not run `start` from the root directory")
}
const home = process.env.HOME
if (cwd === home) {
    errorAndExit("Can not run `start` from the home directory")
}

const {
    org,
    repo,
} = getOrgRepoFromGit()

if (org?.toLowerCase() === "gesht") {
    errorAndExit("Start command is not available for gesht repos. They are not executable/runnable. Run `start` command from a runnable project.")
}

if (org[0] !== org[0].toLowerCase())
    errorAndExit("Invalid Organization. Organization name should start with a lowercase letter.")

if (getDepth() !== 4) {
    errorAndExit("Start should only be run from inside a process (API, panel, site, worker, etc.)")
}

divide()
info("gesht start")
divide()
info(`directory: ${cwd}`)
divide()

let params = {
    home,
    org,
    repo,
}

params.processName = path.basename(cwd)
params.lowercaseOrg = org.toLowerCase()
params.lowercaseRepo = repo.toLowerCase()
params.lowercaseProcess = params.processName.toLowerCase()

success(`organization: ${org}`)
success(`repository: ${repo}`)
success(`process: ${params.processName}`)

params =
{
    ...params,
    ...getPaths(params),
}

const { tenantsPath } = params

if (!isFile(tenantsPath)) {
    errorAndExit(`Tenants file not found at path: ${tenantsPath}`)
}

const lines = getFileLines(tenantsPath)

lines.forEach(line => {
    const parts = line.trim().split(/\s+/)
    let tenant, domain, locales, defaultLocale, roles
    if (parts.length === 5) {
        [tenant, domain, locales, defaultLocale, roles] = parts
        roles = roles.split(',')
    } else if (parts.length === 4) {
        [tenant, domain, locales, defaultLocale] = parts
        roles = []
    } else {
        errorAndExit(`Incomplete tenant line: ${line}`)
    }
    // const localDomain = getLocalHost(domain)
    // createCertificate(tenant, localDomain)
    // setupNginx(tenant, localDomain)
    // setupLocalDns(localDomain)
})

divide()
