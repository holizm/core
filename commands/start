#!/usr/bin/env node

import path from "path"
import process from "process"
import {
    errorAndExit,
    divide,
    info,
    success,
    warning,
} from "../logger.js"
import {
    getDepth,
    getFileLines,
    getOrgRepoFromGit,
    isAccounts,
    isApi,
    isFile,
    isHeadlessPanel,
    isPanel,
    isProcess,
    isSite,
    isWorker,
} from "../scripts/os.js"
import {
    clear,
    runOnTerminal,
} from "../scripts/terminal.js"
import getPaths from "../scripts/getPaths.js"
import getLocalHost from "../scripts/getLocalHost.js"
import createCertificate from "../scripts/createCertificate.js"
import setupNginx from "../scripts/setupNginx.js"
import setupLocalDns from "../scripts/setupLocalDns.js"
import getRandomPort from "../scripts/getRandomPort.js"
import createNetwork from "../scripts/createNetwork.js"
import ensureDependencies from "../scripts/ensureDependencies.js"
import startApi from "../scripts/startApi.js"
import processTenantLine from "../scripts/processTenantLine.js"

clear()

const cwd = process.cwd()
if (cwd === "/") {
    errorAndExit("Can not run `start` from the root directory")
}
const home = process.env.HOME
if (cwd === home) {
    errorAndExit("Can not run `start` from the home directory")
}

const {
    org,
    repo,
} = getOrgRepoFromGit()

if (org?.toLowerCase() === "gesht") {
    errorAndExit("Start command is not available for gesht repos. They are not executable/runnable. Run `start` command from a runnable project.")
}

if (org[0] !== org[0].toLowerCase())
    errorAndExit("Invalid Organization. Organization name should start with a lowercase letter.")

if (getDepth() !== 4) {
    errorAndExit("Start should only be run from inside a process (API, panel, site, worker, etc.)")
}

divide()
info("gesht start")
divide()
info(`directory: ${cwd}`)
divide()

let params = {
    home,
    org,
    repo,
}

params.process = path.basename(cwd)
params.lowercaseOrg = org.toLowerCase()
params.lowercaseRepo = repo.toLowerCase()
params.lowercaseProcess = params.process.toLowerCase()

success(`organization: ${org}`)
success(`repository: ${repo}`)
success(`process: ${params.process}`)

params = {
    ...params,
    ...getPaths(params),
    ...getRandomPort(),
}

const { tenantsPath } = params

if (!isFile(tenantsPath)) {
    errorAndExit(`Tenants file not found at path: ${tenantsPath}`)
}

const lines = getFileLines(tenantsPath)
lines.forEach(line => processTenantLine({ line }))

createNetwork(params)
ensureDependencies(params)
params.composeFile = `/tmp/${repo}/${params.process}/dockerCompose.yml`
divide()


if (isAccounts(params)) {
    startAccounts(params)
} else if (isApi(params)) {
    startApi(params)
} else if (isPanel(params)) {
    if (isHeadlessPanel(params)) {
        startHeadlessPanel(params)
    } else {
        startPanel(params)
    }
} else if (isSite(params)) {
    startSite(params)
} else if (isWorker(params)) {
    startNodeApi(params)
} else {
    warning('Unknown process')
}

let cmd = `docker compose -p ${params.lowercaseRepo}-${params.lowercaseProcess} -f ${params.composeFile} up --remove-orphans`

runOnTerminal(cmd)
