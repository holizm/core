#!/usr/bin/env node

import {
    divide,
    info,
} from '../scripts/logger.js'
import { clear } from '../scripts/terminal.js'
import start from '../scripts/start.js'
import stop from '../scripts/stop.js'
import extract from '../scripts/extract.js'
import build from '../scripts/build.js'
import copyHolismModules from '../scripts/copyHolismModules.js'

clear()
divide()

let params = extract()

await stop({
    pattern: params.containerName
})

params = await start({
    isCiCd: process.argv[2],
    build: true,
})

divide()
info('holism build')
divide()

Object.assign(params, process.env)
copyHolismModules(params)

if (params.isCiCd) {
    await build(params)
}

