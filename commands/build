#!/usr/bin/env node

import {
    divide,
    info,
    warning,
} from '../scripts/logger.js'
import {
    isApi,
    isHeadlessPanel,
    isPanel,
    isSite,
    isWorker,
    replaceVariables,
} from '../scripts/os.js'
import {
    clear,
    runStreaming,
} from '../scripts/terminal.js'

clear()

divide()
info('holism build 2')
divide()
info('holism build after first info')

let params = {}
Object.assign(params, process.env)
info('assigned params')
params.containerFile = `/tmp/build/container`
params.imageName = `ghcr.io/${params.lowercaseOrg}/${params.lowercaseRepo}/${params.lowercaseProcess}:latest`
info('added file and image name')

divide()
info('deciding for type of process')

if (isApi(params)) {
    params.sourceContainerFile = 'api'
} else if (isPanel(params)) {
    if (isHeadlessPanel(params)) {
        params.sourceContainerFile = 'headlessPanel'
    } else {
        params.sourceContainerFile = 'panel'
    }
} else if (isSite(params)) {
    params.sourceContainerFile = 'site'
} else if (isWorker(params)) {
    params.sourceContainerFile = 'worker'
} else {
    warning('Unknown process')
}
info('decided')
params.sourceContainerFile = `${params.home}/core/container/files/prod/${params.sourceContainerFile}`
console.log(params)
info(params)

replaceVariables(params.sourceContainerFile, params.containerFile, params)

let cmd = `docker --debug build \
-f ${params.containerFile} \
-t ${params.imageName} \
/tmp/build --no-cache --progress=plain`
// runStreaming(cmd)
