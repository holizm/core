if (envFile) {
    Object.entries(params).forEach(([key, value]) => {
        if (
            (typeof value === 'string' &&
                value &&
                !value.includes('\n')) ||
            (typeof value === 'boolean' &&
                value)
        ) {
            append(envFile, `${key}=${value}\n`)
        }
    })
}
