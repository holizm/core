#!/usr/bin/env node

import { exec } from 'child_process'
import { readFileSync, writeFileSync } from 'fs'

const getFiles = () => new Promise((resolve, reject) => {
    const cmd = `find . -type f -name "*.jsx" -not -path "*/node_modules/*" -not -path "*/.config/*" -exec grep -Pl "export default\\s+\\w+$" {} +`
    exec(cmd, (err, stdout) => {
        if (err && !stdout) return reject(err)
        resolve(stdout.split('\n').filter(x => x.trim() !== ''))
    })
})

const extractName = content => {
    const m = content.match(/export default\s+(\w+)/)
    console.log(m)
    return m ? m[1] : null
}

getFiles().then(files => {
    files.forEach(f => {
        const content = readFileSync(f, 'utf8')
        const name = extractName(content)
        if (!name) return
        const lines = content.split('\n')
        const idx = lines.findIndex(l => l.includes(`const ${name}`))
        if (idx !== -1) {
            lines[idx] = lines[idx].replace(new RegExp(`const\\s+${name}\\s*=\\s*`), 'export default ')
        }
        const exportIdx = lines.findIndex(l => l.match(new RegExp(`export default\\s*${name}`)))
        if (exportIdx !== -1) {
            lines.splice(exportIdx, 1)
        }
        const cleaned = lines.map(l => l.replace(/\s+$/, ''))
        const finalContent = cleaned.join('\n').replace(/\n*$/, '\n')
        writeFileSync(f, finalContent)
        console.log('updated', f)
    })
});
