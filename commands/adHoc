#!/usr/bin/env node

import { exec } from 'child_process'
import { readFileSync } from 'fs'

const getFiles = () => new Promise((resolve, reject) => {
    const cmd = `find . -type f -name "*.jsx" -not -path "*/node_modules/*" -not -path "*/.config/*" -exec grep -l "export default\\s*[A-Z]" {} +`
    exec(cmd, (err, stdout) => {
        if (err && !stdout) return reject(err)
        resolve(stdout.split('\n').filter(x => x.trim() !== ''))
    })
})

const extractName = content => {
    const m = content.match(/export default\s*([A-Z][A-Za-z0-9_]*)/)
    return m ? m[1] : null
}

getFiles().then(files => {
    files.forEach(f => {
        const content = readFileSync(f, 'utf8')
        const name = extractName(content)
        console.log(f, name)
    })
})
