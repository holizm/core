#!/usr/bin/env node

import { execSync } from 'child_process'
import { readFileSync, writeFileSync } from 'fs'
import { homedir } from 'os'
import path from 'path'
import camelize from '../scripts/camelize.js'

const homeDir = homedir()

const findParts = () => {
    const result = execSync(`find ${homeDir} -maxdepth 2 -type f -name 'part'`, { encoding: 'utf-8' })
    return result.split('\n').filter(Boolean)
}

const processFile = (filePath) => {
    const content = readFileSync(filePath, 'utf-8')
    const camelizedContent = content
        .split(/\s+/)
        .map(word => camelize(word))
        .join(' ')
    writeFileSync(filePath, camelizedContent, 'utf-8')
}

const files = findParts()

files.forEach(file => processFile(file))
