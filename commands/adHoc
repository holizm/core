#!/usr/bin/env bash

ORG=holizm
TEAM_SLUG=readers

gh api "orgs/$ORG/repos?per_page=100" --paginate --jq '.[].name' | while read repo
do
  if gh api "orgs/$ORG/teams/$TEAM_SLUG/repos/$ORG/$repo" >/dev/null 2>&1
  then
    echo "skipped $repo"
  else
    gh api -X PUT "orgs/$ORG/teams/$TEAM_SLUG/repos/$ORG/$repo" -f permission=pull >/dev/null
    echo "added $repo"
  fi
done
