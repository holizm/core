#!/usr/bin/env node

import fs from "fs"
import { execSync } from "child_process"
import path from "path"
import { parse } from "@babel/parser"
import traverseModule from "@babel/traverse"
import generateModule from "@babel/generator"
import camelCase from "lodash.camelcase"

const generate = generateModule.default
const traverse = traverseModule.default

const knownPackages = new Set([
    "react",
    "react-dom",
    "lodash",
    "fs",
    "path",
    "url"
])

function listFiles() {
    const jsFiles = execSync(`find ~ -type f -name "*.js" -not -path "*/node_modules/*"`, { encoding: "utf8" })
        .split("\n")
        .filter(Boolean)

    const jsxFiles = execSync(`find ~ -type f -name "*.jsx" -not -path "*/node_modules/*"`, { encoding: "utf8" })
        .split("\n")
        .filter(Boolean)

    return [...jsFiles, ...jsxFiles]
}

function camelPath(rel) {
    const parts = rel.split("/")
    return parts
        .map(p => (p === "." || p === ".." ? p : camelCase(p)))
        .join("/")
}

function processFile(file) {
    const raw = fs.readFileSync(file, "utf8")
    const ast = parse(raw, { sourceType: "module", plugins: ["jsx"] })

    traverse(ast, {
        ImportDeclaration(p) {
            let source = p.node.source.value

            if (source.startsWith(".")) {
                const dirname = path.dirname(source)
                const basename = path.basename(source)
                const camelDir = dirname === "." ? "." : camelPath(dirname)
                const camelBase = camelCase(basename)
                const updated = dirname === "." ? `./${camelBase}` : `${camelDir}/${camelBase}`
                p.node.source.value = updated
            } else {
                if (!knownPackages.has(source)) {
                    p.node.source.value = camelCase(source)
                }
            }
        }
    })

    const output = generate(ast, { retainLines: true }).code
    fs.writeFileSync(file, output, "utf8")
    console.log(file)
}

const files = listFiles()
for (const file of files) processFile(file)

console.log("Done")
