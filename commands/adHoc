#!/usr/bin/env node

import { exec } from 'child_process'
import { readFileSync, writeFileSync } from 'fs'

const getFiles = () => new Promise((resolve, reject) => {
    const cmd = `find . -type f -name "*.jsx" -not -path "*/node_modules/*" -not -path "*/.config/*" -exec grep -l "export default\\s*[A-Z]" {} +`
    exec(cmd, (err, stdout) => {
        if (err && !stdout) return reject(err)
        resolve(stdout.split('\n').filter(x => x.trim() !== ''))
    })
})

const extractName = content => {
    const m = content.match(/export default\s*([A-Z][A-Za-z0-9_]*)/)
    return m ? m[1] : null
}

getFiles().then(files => {
    files.forEach(f => {
        const content = readFileSync(f, 'utf8')
        const name = extractName(content)
        if (!name) return
        const lines = content.split('\n')
        const idx = lines.findIndex(l => l.includes(`const ${name}`))
        if (idx === -1) return
        const line = lines[idx]
        const replaced = line.replace(new RegExp(`const\\s+${name}\\s*=\\s*`), 'export default ')
        lines[idx] = replaced
        writeFileSync(f, lines.join('\n'))
        console.log('updated', f)
    })
})
