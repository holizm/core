#!/usr/bin/env bash

dirs=$(find ~ -maxdepth 1 -type d \
    -exec sh -c '[ -f "$1/part" ] && [ ! -d "$1/.git" ] && basename "$1"' _ {} \;)

for dir in $dirs; do
    cd ~/"$dir"
    git init
    git remote remove origin 2>/dev/null
    git remote add origin "git@github.com:gesht/$dir"
    git add .
    git commit -m "auto"
    git push -u origin main || git push -u origin master
done
