#!/usr/bin/env bash

homeDir="$HOME"

# Compute default permissions for directories from umask
umask_val=$(umask)
default_perm=$(printf "%o" $(( 0777 & ~0$umask_val )))

find "$homeDir" -maxdepth 1 -type d | while read -r dir; do
    if [ -d "$dir/.git" ]; then
        echo "Processing git repo: $dir"
        find "$dir" -type d | while read -r subdir; do
            sudo chmod "$default_perm" "$subdir"
        done
    fi
done
