#!/usr/bin/env node

import { execSync } from "child_process"
import fs from "fs"
import inflection from "inflection"

const getPartFiles = () => {
    const output = execSync('find /home/dev -type f -name part', { encoding: 'utf-8' })
    return output.split('\n').filter(Boolean)
}

const isTopLevel = line => line.trim().length > 0 && !line.startsWith(' ') && !line.startsWith('\t')

const processFile = filePath => {
    const content = fs.readFileSync(filePath, 'utf-8')

    const updated = content
        .split('\n')
        .map(line => {
            if (!isTopLevel(line)) return line

            const parts = line.trim().split(/\s+/)
            if (parts.length === 0) return line

            const singular = inflection.singularize(parts[0])

            if (singular === parts[0]) return line

            return line.replace(parts[0], singular)
        })
        .join('\n')

    fs.writeFileSync(filePath, updated)
}

const main = () => {
    const files = getPartFiles()
    files.forEach(processFile)
}

main()

