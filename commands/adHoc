#!/usr/bin/env node

import { execSync } from 'child_process'
import { readFileSync, writeFileSync } from 'fs'
import { homedir } from 'os'
import camelize from '../scripts/camelize.js'

const homeDir = homedir()

const processJsonFile = (filePath) => {
    const content = readFileSync(filePath, 'utf-8')
    const json = JSON.parse(content)

    const camelizeKeys = obj => {
        if (Array.isArray(obj)) {
            return obj.map(camelizeKeys)
        } else if (obj && typeof obj === 'object') {
            return Object.fromEntries(
                Object.entries(obj).map(([key, value]) => [camelize(key), camelizeKeys(value)])
            )
        } else {
            return obj
        }
    }

    const camelizedJson = camelizeKeys(json)
    writeFileSync(filePath, JSON.stringify(camelizedJson, null, 4), 'utf-8')
}

const findLocalizationJsons = () => {
    const result = execSync(`find ${homeDir} -type f -path '*/localization/*.json'`, { encoding: 'utf-8' })
    return result.split('\n').filter(Boolean)
}

const jsonFiles = findLocalizationJsons()
jsonFiles.forEach(file => processJsonFile(file))
