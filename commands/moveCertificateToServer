#!/usr/bin/env node

import {
    errorAndExit,
    info,
    divide,
} from '../scripts/logger.js'

import runOnServer from '../scripts/runOnServer.js'
import {
    runStreaming,
} from '../scripts/terminal.js'

const domain = process.argv[2]

if (!domain) {
    errorAndExit('Domain is not provided')
}

divide()
info(`Copying certificate for ${domain}`)
divide()

await runStreaming(
    `sudo cp -L -a /etc/letsencrypt/live/${domain} /tmp/live`
)

await runStreaming(
    `sudo cp -a /etc/letsencrypt/archive/${domain} /tmp/archive`
)

await runStreaming(
    `cd /tmp && sudo zip -r live.zip live`
)

await runStreaming(
    `cd /tmp && sudo zip -r archive.zip archive`
)

await runStreaming(
    `serverCopy /tmp/live.zip ${domain}:/tmp/`
)

await runStreaming(
    `serverCopy /tmp/archive.zip ${domain}:/tmp/`
)

divide()
info('Now run these commands on the server as the root user:')
divide()

info(`rm -rf /etc/letsencrypt/live/${domain} /etc/letsencrypt/archive/${domain} /tmp/live /tmp/archive`)
info(`mkdir -p /etc/letsencrypt/live/${domain} /etc/letsencrypt/archive/${domain}`)
info(`cd /tmp && unzip -o live.zip && unzip -o archive.zip`)
info(`cp -a /tmp/live/* /etc/letsencrypt/live/${domain}/`)
info(`cp -a /tmp/archive/* /etc/letsencrypt/archive/${domain}/`)
info(`rm -rf /tmp/live /tmp/archive /tmp/live.zip /tmp/archive.zip`)

divide()
info('Done')
