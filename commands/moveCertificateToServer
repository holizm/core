#!/usr/bin/env node

import {
    errorAndExit,
    info,
    divide,
} from '../scripts/logger.js'
import runOnServer from '../scripts/runOnServer.js'
import {
    runStreaming,
} from '../scripts/terminal.js'

const domain = process.argv[2]

if (!domain) {
    errorAndExit('Domain is not provided. Usage: moveCertificateToServer <domain>')
}

divide()
info(`Preparing certificate transport for ${domain}`)
divide()

await runStreaming(`sudo rm -f /tmp/live_${domain}.zip /tmp/archive_${domain}.zip`)

await runStreaming(`sudo sh -c "cd /etc/letsencrypt/live/${domain} && zip -r -j /tmp/live_${domain}.zip ."`)
await runStreaming(`sudo sh -c "cd /etc/letsencrypt/archive/${domain} && zip -r -j /tmp/archive_${domain}.zip ."`)

await runStreaming(`sudo chmod 644 /tmp/live_${domain}.zip /tmp/archive_${domain}.zip`)

info(`Uploading archives to ${domain}...`)
await runStreaming(`serverCopy /tmp/live_${domain}.zip ${domain}:/tmp/`)
await runStreaming(`serverCopy /tmp/archive_${domain}.zip ${domain}:/tmp/`)

await runStreaming(`sudo rm -f /tmp/live_${domain}.zip /tmp/archive_${domain}.zip`)

divide()
info('SUCCESS: Files uploaded. Now run these commands on the remote server as root:')
divide()

info(`mkdir -p /etc/letsencrypt/live/${domain} /etc/letsencrypt/archive/${domain}`)
info(`unzip -o /tmp/live_${domain}.zip -d /etc/letsencrypt/live/${domain}/`)
info(`unzip -o /tmp/archive_${domain}.zip -d /etc/letsencrypt/archive/${domain}/`)
info(`rm -f /tmp/live_${domain}.zip /tmp/archive_${domain}.zip`)

divide()
info('Done')
