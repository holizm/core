#!/bin/bash

set -e

basePath="$HOME"
tempDir="/tmp/temp"
repos=("api" "panel" "site")

mkdir -p "$tempDir"
cd "$tempDir"

for repoName in "${repos[@]}"; do
    echo "---- Processing $repoName ----"

    rm -f package.json

    cp "$basePath/$repoName/package.json" .

    npx npm-check-updates -u || true

    cp package.json "$basePath/$repoName/package.json"

    cd "$basePath/$repoName"

    git add package.json

    if ! git diff --cached --quiet; then
        git commit -m "update dependencies"
        git push
    else
        echo "No changes to commit for $repoName"
    fi

    cd "$tempDir"

    echo "---- Done $repoName ----"
done

echo "All repos updated."
