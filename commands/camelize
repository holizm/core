#!/usr/bin/env node
import path from 'path'
import { info } from "../scripts/logger.js"
import camelize from "../scripts/camelize.js"
import { runOnTerminal } from "../scripts/terminal.js"

const list = runOnTerminal('find . -depth')
    .split('\n')
    .filter(Boolean)
    .sort((a, b) => b.split('/').length - a.split('/').length)

for (const p of list) {
    const dir = path.dirname(p)
    const base = path.basename(p)
    const newName = camelize(base)
    if (newName !== base) {
        const newPath = path.join(dir, newName)
        info(base, newName)
        // fs.renameSync(p, newPath)
    }
}
