#!/usr/bin/env node

import { runOnTerminal } from '../scripts/terminal.js'
import {
    getContent,
    writeFile,
} from '../scripts/os.js'

const homeDir = process.env.HOME
const ideDir = `${homeDir}/.config/Code/User`
const coreDir = `${homeDir}/core/ide`

const ideSettingsPath = `${ideDir}/settings.json`
const coreSettingsPath = `${coreDir}/settings.json`

const coreSettings = JSON.parse(getContent(coreSettingsPath))

let userSettingsRaw = getContent(ideSettingsPath, true)
let userSettings
let action = 'overwrite'

try {
    userSettings = JSON.parse(userSettingsRaw)
    action = 'merge'
} catch {
    userSettings = coreSettings
}

const mergeConfig = (coreJson) => {
    const result = { ...userSettings }

    for (const key of Object.keys(coreJson)) {
        result[key] = coreJson[key]
    }

    return result
}

const runnablesOutput = runOnTerminal('runnables')
const runnables = runnablesOutput
    .split('\n')
    .map((line) => line
        .trim()
        .replace(/^\//, '')
        .replace(/-/g, '')
        .trim()
    )
    .filter(Boolean)

const spellingConfiguration = [
    {
        name: 'core',
        path: `${homeDir}/core/ide/dictionary`,
        scope: 'user',
        addWords: true
    }
]

for (const runnable of runnables) {
    spellingConfiguration.push({
        name: runnable,
        path: `${homeDir}/${runnable}/common/dictionary`,
        scope: 'user',
        addWords: true
    })
}

coreSettings['cSpell.customDictionaries'] = spellingConfiguration

const settingsResult =
    action === 'merge'
        ? mergeConfig(coreSettings)
        : coreSettings

writeFile(ideSettingsPath, JSON.stringify(settingsResult, null, 4))

const ideShortcutsPath = `${ideDir}/keybindings.json`
const coreShortcutsPath = `${coreDir}/shortcuts.json`

const getKeybindingsArray = (path) => {
    const raw = getContent(path, true)
    if (!raw) return []

    try {
        const parsed = JSON.parse(raw)
        return Array.isArray(parsed) ? parsed : []
    } catch {
        return []
    }
}

const coreKeybindings = getKeybindingsArray(coreShortcutsPath)
const userKeybindings = getKeybindingsArray(ideShortcutsPath)

const finalKeybindings = [
    ...coreKeybindings,
    ...userKeybindings
]

writeFile(ideShortcutsPath, JSON.stringify(finalKeybindings, null, 4))
