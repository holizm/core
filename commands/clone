#!/usr/bin/env node
import { execSync } from 'child_process'
import fs from 'fs'
import path from 'path'
import {
    divide,
    dividedError,
    info,
    success,
} from "../logger.js"

const DEFAULT_ORG = 'PrimeCoreSolution'
const BASE_DIR = process.env.HOME

const run = cmd => execSync(cmd, { stdio: 'pipe', encoding: 'utf8' })

const repoExists = (org, repo) => {
    try {
        run(`gh repo view ${org}/${repo}`)
        return true
    } catch {
        return false
    }
}

const orgExists = org => {
    try {
        run(`gh api orgs/${org}`)
        return true
    } catch {
        return false
    }
}

const cloneRepo = (org, repo) => {
    const dir = path.join(BASE_DIR, repo)
    if (fs.existsSync(dir)) {
        info(`Skipping ${org}/${repo} (already exists)`)
        return
    }
    info(`Cloning ${org}/${repo}...`)
    run(`mkdir -p ${path.dirname(dir)} && gh repo clone ${org}/${repo} ${dir}`)
    success(`Cloned ${org}/${repo}`)

    const gitignorePath = path.join(BASE_DIR, "core", "gitignore")
    const excludeFile = path.join(dir, '.git', 'info', 'exclude')

    if (fs.existsSync(gitignorePath)) {
        fs.copyFileSync(gitignorePath, excludeFile)
        info(`Copied ${gitignorePath} to ${excludeFile}`)
    } else {
        info(`Gitignore file not found at ${gitignorePath}, skipping copy`)
    }
}

const cloneOrg = org => {
    divide()
    info(`Cloning all repos from ${org}...`)
    divide()
    const output = run(`gh repo list ${org} --limit 1000 --json nameWithOwner -q '.[].nameWithOwner'`)
    const repos = output.trim().split('\n').filter(Boolean)
    for (const full of repos) {
        const [, repo] = full.split('/')
        cloneRepo(org, repo)
    }
}

const [arg1, arg2] = process.argv.slice(2)

if (!arg1) {
    cloneOrg(DEFAULT_ORG)
} else if (!arg2) {
    if (repoExists(DEFAULT_ORG, arg1)) {
        cloneRepo(DEFAULT_ORG, arg1)
    } else if (orgExists(arg1)) {
        cloneOrg(arg1)
    } else {
        dividedError(`Neither repo ${DEFAULT_ORG}/${arg1} nor org ${arg1} exists`)
        process.exit(1)
    }
} else {
    if (!repoExists(arg1, arg2)) {
        dividedError(`Repo ${arg1}/${arg2} does not exist or access denied`)
        process.exit(1)
    }
    cloneRepo(arg1, arg2)
}
